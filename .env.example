# ─── Frontend (Vite) ────────────────────────────────────────────
# UI version toggle (legacy)
VITE_UI_V2=false

# Supabase — frontend client (publishable key is safe to expose)
VITE_SUPABASE_URL=https://hjulojpnpvwsmzckzypb.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# ─── Game server (Rust axum) ────────────────────────────────────
# Project URL
SUPABASE_URL=https://hjulojpnpvwsmzckzypb.supabase.co

# Secret — verifies login JWTs coming from the frontend.
# Supabase dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=

# Secret — Postgres connection for persisting games.
# IMPORTANT: use the SESSION POOLER host, not the direct db.<ref> host — the
# direct host is IPv6-only and unreachable from IPv4-only networks.
# Dashboard → Settings → Database → Connection string → URI → "Session" pooler.
# Username is postgres.<ref>; percent-encode reserved chars in the password
# (e.g. '@' → %40). Append ?sslmode=require.
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=

# Where the engine reads competition/team/player JSON from.
OLM_DATA_DIR=./data

# Where the import endpoint writes photos (the frontend serves this dir).
OLM_PUBLIC_DIR=./public

# Enable the destructive data-import endpoint (Settings → Datos in web mode).
# Off by default; set to 1 only where importing global game data is intended.
OLM_ALLOW_IMPORT=0

# ─── Automatic OLMDBManager data import (web API startup) ───────────────
# Local dev default used by `npm run dev:web:api`:
#   OLM_AUTO_IMPORT=1 OLM_IMPORT_SOURCE=http://localhost:3000/api/olm/export
# In production, point this at the deployed OLMDBManager endpoint:
# OLM_IMPORT_SOURCE=https://<olmdbmanager-host>/api/olm/export
OLM_AUTO_IMPORT=0
OLM_IMPORT_SOURCE=
