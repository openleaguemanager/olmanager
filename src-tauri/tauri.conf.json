{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Open League Manager",
  "version": "0.3.1",
  "identifier": "com.openleaguemanager.olmanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && powershell -Command \"$null = Remove-Item -Recurse -Force 'src-tauri/data' -ErrorAction SilentlyContinue; Copy-Item -Recurse -Force 'data' 'src-tauri/data' \"",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Open League Manager 0.3.1",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [
      "databases/world.json",
      "data/competitions/*/manifest.json",
      "data/teams/*.json",
      "data/players/*.json",
      "data/staffs/*.json",
      "data/erls/competitions/*/manifest.json",
      "data/erls/teams/*.json",
      "data/erls/players/*.json",
      "data/draft/*.json"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJCN0EyN0VBQkU1NjBGM0IKUldRN0QxYSs2aWQ2dTBiSEluRGErRlFwRjkweStKTXljZmFlUEhXQlMvdFlYaFlnZTQ5V3Zqdk4K",
      "endpoints": [
        "https://github.com/OpenLeagueManager/OLManager/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
